# ============================================
# Heirloom Project - Environment Variables
# ============================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to `.env` in the same directory
# 2. Replace placeholder values with your actual credentials
# 3. Never commit the `.env` file to version control
#
# The `.env` file is already listed in .gitignore for security
#
# ============================================

# BOB Platform API Integration
# ---------------------------------------------
# This API key enables deep integration between Heirloom (knowledge management)
# and the Bob Platform (productivity tracking system).
#
# To obtain your API key:
# 1. Log in to your Bob Platform account
# 2. Navigate to Settings > API Keys
# 3. Generate a new API key for Heirloom integration
# 4. Copy the key and paste it below
#
# IMPORTANT: Keep this key secure and never share it publicly
BOB_API_KEY=your_bob_api_key_here

# Watsonx AI Configuration
# ---------------------------------------------
# These credentials enable AI-powered chat features in the WhyChat component,
# allowing intelligent conversations with historical personas using IBM Watsonx.
#
# To obtain your Watsonx credentials:
# 1. Log in to IBM Cloud (https://cloud.ibm.com)
# 2. Navigate to your Watsonx.ai project
# 3. Go to Project Settings > Manage > Access & credentials
# 4. Copy your API key from the IBM Cloud API Keys section
# 5. Copy your Project ID from the project details
# 6. The URL is typically https://us-south.ml.cloud.ibm.com (adjust for your region)
#
# Supported regions:
# - US South: https://us-south.ml.cloud.ibm.com
# - EU Germany: https://eu-de.ml.cloud.ibm.com
# - Japan Tokyo: https://jp-tok.ml.cloud.ibm.com
#
# IMPORTANT: Keep these credentials secure and never share them publicly
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com